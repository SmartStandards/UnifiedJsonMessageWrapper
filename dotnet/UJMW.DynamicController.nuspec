<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>UJMW.DynamicController</id>
    <version>5.4.0</version>
    <title>UJMW.DynamicController (for ASP core WebApi)</title>
    <authors>SmartStandards</authors>
    <owners>(public domain)</owners>
    <copyright>SmartStandards</copyright>
    <description>A dynamic Service-Facade (Controller) for ASP core WebApi, using the 'Unified JSON Message Wrapper' standard</description>
    <tags>UJMW REST JSON ASP.NET MVC WebApi</tags>
    <!-- https://spdx.org/licenses/ -->
    <license type="expression">GPL-3.0-only</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <icon>PackageIcon.png</icon>
    <projectUrl>https://github.com/SmartStandards/UnifiedJsonMessageWrapper</projectUrl>
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="Newtonsoft.Json" version="13.0.3" />
        <!--
        <dependency id="Microsoft.AspNetCore" version="2.2.0" />
        <dependency id="Microsoft.AspNetCore.Mvc" version="2.2.0" />
        <dependency id="Microsoft.AspNetCore.Mvc.Core" version="2.2.5" />
        <dependency id="System.Text.Encodings.Web" version="6.0.0" />
        -->      
      </group>
      <group targetFramework="net10.0">
        <dependency id="Newtonsoft.Json" version="13.0.4" />
        <!-- additional packages which are note implicitely provided by 'Microsoft.AspNetCore.App' -->
        <dependency id="Microsoft.AspNetCore.OpenApi" version="10.0.8" />
        <dependency id="Microsoft.AspNetCore.Authentication.Negotiate" version="10.0.8" />
        <dependency id="Microsoft.AspNetCore.Authentication.OpenIdConnect" version="10.0.8" />
        <!-- intermediate (until we've completely switched to 'Microsoft.AspNetCore.OpenApi' -->
        <dependency id="Swashbuckle.AspNetCore" version="10.1.7" />
        <dependency id="Swashbuckle.AspNetCore.Annotations" version="10.1.7" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- https://docs.microsoft.com/en-us/nuget/create-packages/creating-a-package#from-a-convention-based-working-directory -->
    <file src="PackageIcon.png" target="" />
    <!-- .NET 8.0 -->
    <file src="dist\bin-net8.0\UJMW.DynamicController.dll" target="lib/net8.0" />
    <file src="dist\bin-net8.0\UJMW.DynamicController.xml" target="lib/net8.0" />
    <file src="dist\bin-net8.0\UJMW.DynamicController.pdb" target="lib/net8.0" />
    <!-- .NET 10.0 -->
    <file src="dist\bin-net10.0\UJMW.DynamicController.dll" target="lib/net10.0" />
    <file src="dist\bin-net10.0\UJMW.DynamicController.xml" target="lib/net10.0" />
    <file src="dist\bin-net10.0\UJMW.DynamicController.pdb" target="lib/net10.0" />
  </files>
</package>
